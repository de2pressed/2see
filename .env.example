# Required for Llama verification through Groq's OpenAI-compatible API.
GROQ_API_KEY=

# Optional fallback key. The app currently targets Groq by default.
OPENAI_API_KEY=

# Optional search providers. Configure at least one for production accuracy.
TAVILY_API_KEY=
SERPER_API_KEY=

# Optional local/test controls.
DISABLE_CLAIM_CACHE=
SEARCH_FIXTURES_DIR=
